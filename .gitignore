# Self-contained .gitignore — this satellite is structured to be
# extractable as its own repo, so don't rely on a parent .gitignore.

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

*.egg-info/
*.egg

# build outputs (wheel + sdist)
build/
dist/

# test + lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# virtual envs
.venv/
venv/
.venv-*/
env/

# ── Wrapper artifacts ─────────────────────────────────────────────────
wrapper/__pycache__/
wrapper/*.bak

# ── Logs ──────────────────────────────────────────────────────────────
*.log

# ── Editor / OS ───────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*~

# ── Env files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
